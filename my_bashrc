# timer
# no para, show s running timer
# 1 para, sleep for specified time, alarm
# example timer 10s/1h/1m, default to s
function timer(){
  if [ "$#" -eq 0 ]; then
    local dd=$(date +%H:%M:%S:%N-ns)
    echo "$dd"
    while true; do d=$(date +%H:%M:%S:%N-ns); echo -en "\r$d"; done
  else 
    if [[ $1 =~ ^[0-9]+$ ]]; then
      # we have a number
      # disown to not show "Done..."
      (sleep "$1" ; echo -e "\a ${1}s has elapsed") & disown
    else
      (sleep "$1" ; echo -e "\a $1 has elapsed") & disown
    fi
  fi
}

# swap 2 files
# 2 files must have same file extension
function swap_file(){
  if [ "$#" -ne 2 ]; then
    echo "expecting 2 files"
    return 0; # not an error, No-op
  fi

  if [ ! -f "$1" ]; then
    echo "$1 is not a file"
    return 0;
  fi

  if [ ! -f "$2" ]; then
    echo "$2 is not a file"
    return 0;
  fi

  # para expansion to find file extension
  local ext1="${1#*.}"
  local ext2="${2#*.}"
  [ "$ext1" = "$1" ] && ext1="" # handle no extension case
  [ "$ext2" = "$2" ] && ext2="" 
  if [ ! "$ext1" = "$ext2" ]; then
    echo "file type does not match"
    return 0
  fi

  if [ -z "$ext1" ]; then # no extension case
    echo "$1 has not file extension"
    return 0
  fi

  if [ -z "$ext2" ]; then # no extension case
    echo "$2 has not file extension"
    return 0
  fi

  # swap file
  local TMP_FILE=$(mktemp -q ./tmp.XXXXXXXX)
  if [ $? -ne 0 ]; then
    echo "can't create temp file"
    return 0
  fi

  mv "$1" $TMP_FILE && mv "$2" "$1" && mv $TMP_FILE "$2"
}

# remove temp files
function tmp_remove(){
  local current_dir=$(pwd -P)
  cd /tmp && yes | rm -rf ./* 2>/dev/null
  cd $HOME/.vim_temp && yes | rm -rf ./* 2>/dev/null
  cd "$current_dir"
}


# pp is for pushd-popd combined
# for a file, pushd into its containing dir
# for a dir, pushd to the dir 
# if no para, do popd
function pp(){
  if [[ -d "$1" ]]; then
    pushd "$1" > /dev/null
  elif [[ -f "$1" ]]; then
    pushd $(dirname "$1") > /dev/null
  else
    popd > /dev/null 
  fi
}

# find all git repo's in current dir
# if 1 para, find a git repo with its path matching the pattern
# if 0 para, list all git repo in current dir
function gitrepo(){
  if [ "$#" -eq 1 ]; then
    find . -name "*.git" |xargs dirname |grep -P "$1"
  else
    find . -name "*.git" |xargs dirname
  fi
}

# match files path with patterns, ignore hidden
# ff pattern
# ff pattern_1 pattern_2
# ff pattern_1 pattern_2 pattern_3
function ff(){
  local my_file=$(mktemp /tmp/fdf_johnzli_XXXXXXXX)
  find . -type f -iname "README" -or -name "*.sh" -or -name "*.py" -or -name "*.lua" \
    -or -name "*.h" -or -name "*.c" -or -name "*.cpp" -or -name "*.cc" -or -name "*.hh" \
    -or -name "*.rs" -or -name "*.hs" -or -name "*.ysh" > "$my_file"
  if [ "$#" -eq 1 ]; then
    grep -P "$1" "$my_file"  |grep -v -P '\/\..*'
  elif [ "$#" -eq 2 ]; then
    grep -P "$1" "$my_file"  |grep -P "$2" |grep -v -P '\/\..*'
  elif [ "$#" -eq 3 ]; then
    grep -P "$1" "$my_file"  |grep -P "$2" |grep -P "$2" |grep -v -P '\/\..*'
  fi
  rm $my_file
}

# match file lines
# fl pattern: find the files that contain the pattern
# fl pattern1 pattern2 find the files that contain pattern1 in files returned by 'ff pattern2'
# fl pattern1 pattern2 pattern3, find files that contain pattern1 in files returned by 'ff pattern2 pattern3'
function fl(){
  if [ "$#" -eq 1 ]; then
    find . -type f -iname "README" -or -name "*.sh" -or -name "*.py" -or -name "*.lua" \
      -or -name "*.h" -or -name "*.c" -or -name "*.cpp" -or -name "*.cc" -or -name "*.hh" \
      -or -name "*.rs" -or -name "*.hs" -or -name "*.ysh" \
     |xargs grep -s -n -P "$1" |grep -v -P '\/\..*'
  else 
    # forward para from 2
    ff "${@:2}" |xargs grep -n -P "$1"
  fi
}

# sort by length then alphanumerically,
# get input from stdin
# also remove duplicate items
# "-f2-" in cut to handle the case there is space in input
function sort_by_len(){
  # naked cat to get input from stdin
  cat |awk '{ print length, $0}' |sort -u -n -k1,1 -k2 |cut -d' ' -f2-
}

# backward cd
# bd select from sub-dirs of parent dir up to deptth-3 dirs
# bd pattern, search in sub-dirs of parent dir, only show the first 25 match
# bd pattern1 .. up to 3, same as above but match all patterns
# after selection, "pp" into the dir
function bd(){
  local arr=()
  # 'find /path/to/dir -mindepth 1 -type d ' to find all sub-dir but no root dir
  # -not -path '*/*' ignores hidden dirs
  if [ "$#" -eq 0 ]; then
   arr=($(find .. -maxdepth 3 -not -path '*/.*' -type d 2>/dev/null |sort_by_len |head -n 25 )) 
  elif [ "$#" -eq 1 ]; then
   arr=($(find .. -mindepth 2 -not -path '*/.*' -type d 2>/dev/null |grep -P "$1" |sort_by_len |head -n 25 )) 
  elif [ "$#" -eq 2 ]; then
   arr=($(find .. -mindepth 2 -not -path '*/.*' -type d 2>/dev/null |grep -P "$1" |grep -P "$2" |sort_by_len |head -n 25 )) 
  elif [ "$#" -eq 2 ]; then
   arr=($(find .. -mindepth 2 -not -path '*/.*' -type d 2>/dev/null |grep -P "$1" |grep -P "$2" |grep -P "$3" |sort_by_len |head -n 25 )) 
  fi

  local result=()
  # convert path to be relative to current PWD
  for element in "${arr[@]}"; do
    result+=("$(realpath --relative-to="$PWD" "$element")")
  done
  
  # select path
  select opt in "${result[@]}"
  do 
    case $opt in
        *) break
           ;;
    esac
  done

  if [[ "$opt" ]]; then
      pushd "$opt" > /dev/null
  fi
}

# search in history
function hd(){
  # the awk command is to remove duplicate without sorting
  grep -w -a "$1" $HISTFILE |grep -v '^hd' --no-filename |awk '!x[$0]++' |tail -n25
}

# undo last commit, keep changes staged
function git_backstep(){
  git reset --soft HEAD~1
  echo "commit again with a better commit sessage"
}

